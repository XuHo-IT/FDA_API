  ' Repository manages Entity relationships
  IAlertRepository ..> Alert : manages
  IAlertRuleRepository ..> AlertRule : manages
  IUserAlertSubscriptionRepository ..> UserAlertSubscription : manages
  INotificationLogRepository ..> NotificationLog : manages
