  interface INotificationLogRepository {
    + CreateAsync(entity, ct): Task<Guid>
    + UpdateAsync(entity, ct): Task<bool>
    + GetPendingNotificationsAsync(maxRetries, ct): Task<IEnumerable<NotificationLog>>
    + GetByUserIdAsync(userId, skip, take, ct): Task<IEnumerable<NotificationLog>>
    + IsUserNotifiedAsync(userId, alertId, ct): Task<bool>
    + GetPendingAndRetryNotificationsAsync(limit, ct): Task<List<NotificationLog>>
  }

  interface ISensorReadingRepository {
    + GetLatestReadingsByStationsAsync(stationIds, ct): Task<IEnumerable<SensorReading>>
  }

  interface IStationRepository {
    + GetAllAsync(ct): Task<IEnumerable<Station>>
    + GetByIdAsync(id, ct): Task<Station?>
  }

  interface IAreaRepository {
    + GetAreasContainingStationAsync(stationId, lat, lng, ct): Task<List<Area>>
  }

  interface IUserRepository {
    + GetByIdAsync(id, ct): Task<User?>
  }

  interface IUserSubscriptionRepository {
    + GetUserTierAsync(userId, ct): Task<SubscriptionTier>
  }

  interface IGlobalThresholdService {
    + CalculateSeverity(value): (string severity, int level)
