  }

  class SensorReading <<Entity>> {
    + Id: Guid
    + StationId: Guid
    + Value: double
    + Distance: double
    + SensorHeight: double
    + Unit: string
    + Status: int
    + MeasuredAt: DateTime
    + CreatedBy: Guid
    + CreatedAt: DateTime
    + UpdatedBy: Guid
    + UpdatedAt: DateTime
    --
    + Station: Station?
  }

  class User <<Entity>> {
    + Id: Guid
    + Email: string
    + PhoneNumber: string?
    + FullName: string?
    + FcmToken: string?
    + PasswordHash: string?
    + AvatarUrl: string?
    + Provider: string
    + Status: string
    + EmailVerifiedAt: DateTime?
    + PhoneVerifiedAt: DateTime?
    + LastLoginAt: DateTime?
    + CreatedAt: DateTime
    + UpdatedAt: DateTime
  }

  ' Entity Relationships
  AlertRule "1" *-- "many" Alert : triggers
  Alert "1" *-- "many" NotificationLog : generates
  Station "1" *-- "many" Alert : has
  Station "1" *-- "many" SensorReading : has
  Station "1" *-- "many" AlertRule : has
  User "1" *-- "many" UserAlertSubscription : has
  User "1" *-- "many" NotificationLog : receives
}

