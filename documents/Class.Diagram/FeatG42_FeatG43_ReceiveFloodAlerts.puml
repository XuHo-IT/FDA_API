title FeatG42 & FeatG43 - Receive Flood Alerts - Class Diagram\n(Domain-Centric Architecture + CQRS Pattern)

' ============================================
' PRESENTATION LAYER
' ============================================
package "PRESENTATION LAYER" #E1D5E7 {

  class AlertProcessingJob <<BackgroundJob>> {
    + ExecuteAsync(ct): Task
  }

  class NotificationDispatchJob <<BackgroundJob>> {
    + ExecuteAsync(ct): Task
  }
}

' ============================================
' APPLICATION LAYER
' ============================================
package "APPLICATION LAYER" #D5E8D4 {

  ' --- ProcessAlerts Feature (G42) ---
  class ProcessAlertsRequest <<Record>> {
  }

  class ProcessAlertsResponse <<Response>> {
    + Success: bool
    + Message: string
    + AlertsCreated: int
    + AlertsUpdated: int
    + AlertsPending: int
  }

  class ProcessAlertsHandler <<Handler>> {
    - _ruleRepo: IAlertRuleRepository
    - _sensor_repo: ISensorReadingRepository
    - _alert_repo: IAlertRepository
    - _cooldown_repo: IAlertCooldownConfigRepository
    - _station_repo: IStationRepository
    - _globalThresholdService: IGlobalThresholdService
    - _logger: ILogger<ProcessAlertsHandler>
    --
    + Handle(request, ct): Task<ProcessAlertsResponse>
    - ProcessCustomRule(rule, reading, ct): Task<(int, int, int)>
    - ProcessGlobalThreshold(reading, ct): Task<(int, int, int)>
    - HandleExistingAlert(alert, reading, ct): Task<string>
    - CreateNewAlert(ruleId, stationId, severity, reading, ct): Task
    - MapSeverityToPriority(severity): NotificationPriority
  }

  interface "IRequestHandler<ProcessAlertsRequest, ProcessAlertsResponse>" as IRequestHandler_G42
  ProcessAlertsHandler ..|> IRequestHandler_G42 : implements

  ' --- DispatchNotifications Feature (G43) ---
  class DispatchNotificationsRequest <<Record>> {
  }

  class DispatchNotificationsResponse <<Response>> {
    + Success: bool
    + Message: string
    + NotificationsCreated: int
    + NotificationsSent: int
    + NotificationsFailed: int
    + AlertsProcessed: int
  }

  class DispatchNotificationsHandler <<Handler>> {
    - _alert_repo: IAlertRepository
    - _subscription_repo: IUserAlertSubscriptionRepository
    - _user_repo: IUserRepository
    - _notificationLog_repo: INotificationLogRepository
    - _routingService: IPriorityRoutingService
    - _templateService: INotificationTemplateService
    - _dispatchService: INotificationDispatchService
    - _station_repo: IStationRepository
    - _area_repo: IAreaRepository
    - _userSubscription_repo: IUserSubscriptionRepository
    - _logger: ILogger<DispatchNotificationsHandler>
    --
    + Handle(request, ct): Task<DispatchNotificationsResponse>
    - IsInQuietHours(start, end): bool
    - FilterChannelsByPreferences(channels, subscription): List<NotificationChannel>
    - GetDestination(user, channel): string
  }

  interface "IRequestHandler<DispatchNotificationsRequest, DispatchNotificationsResponse>" as IRequestHandler_G43
  DispatchNotificationsHandler ..|> IRequestHandler_G43 : implements

  ' Relationships
  ProcessAlertsHandler --> ProcessAlertsRequest : handles
  ProcessAlertsHandler --> ProcessAlertsResponse : returns
  DispatchNotificationsHandler --> DispatchNotificationsRequest : handles
  DispatchNotificationsHandler --> DispatchNotificationsResponse : returns
}

' ============================================
' DOMAIN LAYER - ENTITIES
' ============================================
