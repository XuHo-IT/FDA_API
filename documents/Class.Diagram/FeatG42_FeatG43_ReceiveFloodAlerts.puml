    + Id: Guid
    + AlertRuleId: Guid?
    + StationId: Guid
    + TriggeredAt: DateTime
    + ResolvedAt: DateTime?
    + Status: string
    + Severity: string
    + Priority: NotificationPriority
    + CurrentValue: decimal
    + Message: string
    + NotificationSent: bool
    + NotificationCount: int
    + LastNotificationAt: DateTime?
    + CreatedBy: Guid
    + CreatedAt: DateTime
    + UpdatedBy: Guid
    + UpdatedAt: DateTime
    --
    + AlertRule: AlertRule?
    + Station: Station?
    + NotificationLogs: ICollection<NotificationLog>?
  }

  class AlertRule <<Entity>> {
    + Id: Guid
    + StationId: Guid
    + Name: string
    + RuleType: string
    + ThresholdValue: decimal
    + DurationMin: int?
    + Severity: string
    + IsActive: bool
    + IsGlobalDefault: bool
    + MinTierRequired: SubscriptionTier
    + CreatedBy: Guid
    + CreatedAt: DateTime
    + UpdatedBy: Guid
    + UpdatedAt: DateTime
    --
    + Station: Station?
    + Alerts: ICollection<Alert>?
  }

  class AlertCooldownConfig <<Entity>> {
    + Id: Guid
    + Severity: string
    + CooldownMinutes: int
    + CreatedAt: DateTime
  }

  class UserAlertSubscription <<Entity>> {
    + Id: Guid
    + UserId: Guid
    + AreaId: Guid?
    + StationId: Guid?
    + MinSeverity: string
    + EnablePush: bool
    + EnableEmail: bool
    + EnableSms: bool
    + QuietHoursStart: TimeSpan?
    + QuietHoursEnd: TimeSpan?
    + CreatedBy: Guid
    + CreatedAt: DateTime
    + UpdatedBy: Guid
    + UpdatedAt: DateTime
    --
    + User: User?
    + Station: Station?
    + Area: Area?
  }

  class NotificationLog <<Entity>> {
    + Id: Guid
    + UserId: Guid
    + AlertId: Guid
    + Channel: NotificationChannel
    + Destination: string
    + Content: string
    + Title: string?
    + Priority: NotificationPriority
    + RetryCount: int
    + MaxRetries: int
    + Status: string
    + SentAt: DateTime?
    + DeliveredAt: DateTime?
    + ErrorMessage: string?
    + CreatedBy: Guid
    + CreatedAt: DateTime
    + UpdatedBy: Guid
    + UpdatedAt: DateTime
    --
    + User: User?
    + Alert: Alert?
  }

  class Station <<Entity>> {
    + Id: Guid
    + Code: string
    + Type: string
    + Name: string
    + LocationDesc: string
    + Latitude: decimal?
    + Longitude: decimal?
    + RoadName: string
    + Direction: string
    + Status: string
    + ThresholdWarning: decimal?
    + ThresholdCritical: decimal?
    + AdministrativeAreaId: Guid?
    + InstalledAt: DateTimeOffset?
    + LastSeenAt: DateTimeOffset?
