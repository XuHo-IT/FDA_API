@startuml FeatG44-46_FloodAnalytics_ClassDiagram
!define RECTANGLE class

skinparam backgroundColor #FEFEFE
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #000000
skinparam packageBackgroundColor #E8E8E8
skinparam packageBorderColor #666666
skinparam stereotypeCBackgroundColor #ADD1B2
skinparam arrowColor #333333

title FeatG44-46 - Flood Analytics (History / Trends / Statistics)\n(Domain-Centric Architecture + CQRS Pattern)

' ============================================
' APPLICATION LAYER - HISTORY (G44)
' ============================================
package "APPLICATION LAYER - HISTORY (G44)" #D5E8D4 {
  class GetFloodHistoryRequest <<Record>> {
    + StationId: Guid?
    + StationIds: List<Guid>?
    + AreaId: Guid?
    + StartDate: DateTime?
    + EndDate: DateTime?
    + Granularity: string
    + Limit: int
    + Cursor: string?
  }

  class GetFloodHistoryResponse <<Response>> {
    + Success: bool
    + Message: string
    + StatusCode: FloodHistoryStatusCode
    + Data: FloodHistoryDto?
    + Pagination: PaginationDto?
  }

  class GetFloodHistoryHandler <<Handler>> {
    - _sensorReadingRepository: ISensorReadingRepository
    - _hourlyAggRepository: ISensorHourlyAggRepository
    - _dailyAggRepository: ISensorDailyAggRepository
    - _stationRepository: IStationRepository
    - _mapper: IFloodHistoryMapper
    --
    + Handle(request, ct): Task<GetFloodHistoryResponse>
    - GetRawDataPoints(): Task<List<FloodDataPointDto>>
    - GetHourlyDataPoints(): Task<List<FloodDataPointDto>>
    - GetDailyDataPoints(): Task<List<FloodDataPointDto>>
    - DetectMissingIntervals(): int
  }

  class GetFloodHistoryRequestValidator <<Validator>> {
  }
}

' ============================================
' APPLICATION LAYER - TRENDS (G45)
' ============================================
package "APPLICATION LAYER - TRENDS (G45)" #D5E8D4 {
  class GetFloodTrendsRequest <<Record>> {
    + StationId: Guid
    + Period: string
    + StartDate: DateTime?
    + EndDate: DateTime?
    + Granularity: string
    + CompareWithPrevious: bool
  }

  class GetFloodTrendsResponse <<Response>> {
    + Success: bool
    + Message: string
    + StatusCode: FloodHistoryStatusCode
    + Data: FloodTrendDto?
  }

  class GetFloodTrendsHandler <<Handler>> {
    - _dailyAggRepository: ISensorDailyAggRepository
    - _stationRepository: IStationRepository
    - _mapper: IFloodHistoryMapper
    --
    + Handle(request, ct): Task<GetFloodTrendsResponse>
    - CalculateDateRange(): (DateTime, DateTime)
    - AggregateToWeekly(): List<FloodTrendDataPointDto>
    - AggregateToMonthly(): List<FloodTrendDataPointDto>
    - CalculateComparison(): Task<FloodTrendComparisonDto?>
  }

  class GetFloodTrendsRequestValidator <<Validator>> {
  }
}

' ============================================
' APPLICATION LAYER - STATISTICS (G46)
' ============================================
package "APPLICATION LAYER - STATISTICS (G46)" #D5E8D4 {
  class GetFloodStatisticsRequest <<Record>> {
    + StationId: Guid?
    + StationIds: List<Guid>?
    + AreaId: Guid?
    + Period: string
    + IncludeBreakdown: bool
    + IncludeComparison: bool
  }

  class GetFloodStatisticsResponse <<Response>> {
    + Success: bool
    + Message: string
    + StatusCode: FloodHistoryStatusCode
    + Data: FloodStatisticsDto?
  }

  class GetFloodStatisticsHandler <<Handler>> {
    - _dailyAggRepository: ISensorDailyAggRepository
    - _stationRepository: IStationRepository
    - _mapper: IFloodHistoryMapper
    --
    + Handle(request, ct): Task<GetFloodStatisticsResponse>
    - CalculateDateRange(): (DateTime, DateTime)
    - CalculateSummary(): FloodStatisticsSummaryDto
    - CalculateSeverityBreakdown(): FloodStatisticsSeverityBreakdownDto
    - CalculateComparison(): Task<FloodTrendComparisonDto?>
    - CalculateDataQuality(): DataQualityDto
  }

  class GetFloodStatisticsRequestValidator <<Validator>> {
  }
}

' ============================================
' SHARED APPLICATION COMPONENTS
' ============================================
package "SHARED - APPLICATION" #D5E8D4 {
  interface IRequestHandler {
    + Handle(request, ct): Task<Response>
  }

  enum FloodHistoryStatusCode <<Enumeration>> {
    Success
    BadRequest
    NotFound
    InternalServerError
  }

  class FloodHistoryDto <<DTO>> {
    + StationId: Guid
    + StationName: string
    + StationCode: string
    + DataPoints: List<FloodDataPointDto>
    + Metadata: FloodHistoryMetadataDto
  }

  class FloodTrendDto <<DTO>> {
    + StationId: Guid
    + StationName: string
    + StationCode: string
    + Period: string
    + Granularity: string
    + DataPoints: List<FloodTrendDataPointDto>
    + Comparison: FloodTrendComparisonDto?
    + Summary: FloodTrendSummaryDto
  }

  class FloodStatisticsDto <<DTO>> {
    + StationId: Guid
    + StationName: string
    + StationCode: string
    + PeriodStart: DateTime
    + PeriodEnd: DateTime
    + Summary: FloodStatisticsSummaryDto
    + SeverityBreakdown: FloodStatisticsSeverityBreakdownDto?
    + Comparison: FloodTrendComparisonDto?
    + DataQuality: DataQualityDto
  }

  class FloodDataPointDto <<DTO>> {
    + Timestamp: DateTime
    + WaterLevel: double
    + Rainfall: double?
    + Severity: int
  }

  class FloodTrendDataPointDto <<DTO>> {
    + Period: string
    + PeriodStart: DateTime
    + PeriodEnd: DateTime
    + MaxLevel: double
    + MinLevel: double
    + AvgLevel: double
    + FloodHours: int
    + PeakSeverity: int
  }

  class PaginationDto <<DTO>> {
    + HasMore: bool
    + TotalCount: int
  }

  GetFloodHistoryHandler ..|> IRequestHandler
  GetFloodTrendsHandler ..|> IRequestHandler
  GetFloodStatisticsHandler ..|> IRequestHandler

  GetFloodHistoryResponse --> FloodHistoryStatusCode
  GetFloodTrendsResponse --> FloodHistoryStatusCode
  GetFloodStatisticsResponse --> FloodHistoryStatusCode
}

' ============================================
' DOMAIN LAYER - Entities
' ============================================
package "DOMAIN LAYER - Entities" #F8CECC {
  class SensorReading <<Entity>> {
    + Id: Guid
    + StationId: Guid
    + WaterLevel: decimal
    + Rainfall: decimal?
    + Timestamp: DateTime
    + Severity: int
  }

  class SensorHourlyAgg <<Entity>> {
    + StationId: Guid
    + Timestamp: DateTime
    + AvgLevel: decimal
    + MaxLevel: decimal
    + MinLevel: decimal
    + ReadingCount: int
    + FloodHours: int
  }

  class SensorDailyAgg <<Entity>> {
    + StationId: Guid
    + Date: DateOnly
    + AvgLevel: decimal
    + MaxLevel: decimal
    + MinLevel: decimal
    + ReadingCount: int
    + FloodHours: int
    + PeakSeverity: int
    + RainfallTotal: decimal?
  }

  class Station <<Entity>> {
    + Id: Guid
    + Name: string
    + Code: string
    + Latitude: decimal
    + Longitude: decimal
  }

  Station "1" *-- "many" SensorReading
  Station "1" *-- "many" SensorHourlyAgg
  Station "1" *-- "many" SensorDailyAgg
}

' ============================================
' DOMAIN LAYER - Repositories
' ============================================
package "DOMAIN LAYER - Repositories" #FFE6CC {
  interface ISensorReadingRepository <<Interface>> {
    + GetByStationAndTimeRangeAsync(stationId, start, end, limit, ct): Task<List<SensorReading>>
  }

  interface ISensorHourlyAggRepository <<Interface>> {
    + GetByStationAndRangeAsync(stationId, start, end, ct): Task<List<SensorHourlyAgg>>
  }

  interface ISensorDailyAggRepository <<Interface>> {
    + GetByStationAndRangeAsync(stationId, start, end, ct): Task<List<SensorDailyAgg>>
  }

  interface IStationRepository <<Interface>> {
    + GetByIdAsync(id: Guid, ct): Task<Station?>
  }
}

' ============================================
' COMMON SERVICES
' ============================================
package "COMMON SERVICES" #E1D5E7 {
  interface IMediator <<Interface>> {
    + Send<TResponse>(request, ct): Task<TResponse>
  }

  interface IFloodHistoryMapper <<Interface>> {
    + MapToDataPoints(readings): List<FloodDataPointDto>
    + MapToDataPoints(hourlyAggs): List<FloodDataPointDto>
    + MapToDataPoints(dailyAggs): List<FloodDataPointDto>
    + MapToTrendDataPoints(dailyAggs): List<FloodTrendDataPointDto>
  }

  interface IFeatureRequest <<Interface>> { }
  interface IFeatureResponse <<Interface>> { }

  GetFloodHistoryRequest ..|> IFeatureRequest
  GetFloodHistoryResponse ..|> IFeatureResponse
  GetFloodTrendsRequest ..|> IFeatureRequest
  GetFloodTrendsResponse ..|> IFeatureResponse
  GetFloodStatisticsRequest ..|> IFeatureRequest
  GetFloodStatisticsResponse ..|> IFeatureResponse
}

' ============================================
' RELATIONSHIPS
' ============================================
GetFloodHistoryHandler --> GetFloodHistoryRequest : handles
GetFloodHistoryHandler --> GetFloodHistoryResponse : returns
GetFloodHistoryHandler ..> ISensorReadingRepository : uses
GetFloodHistoryHandler ..> ISensorHourlyAggRepository : uses
GetFloodHistoryHandler ..> ISensorDailyAggRepository : uses
GetFloodHistoryHandler ..> IStationRepository : uses
GetFloodHistoryHandler ..> IFloodHistoryMapper : uses

GetFloodTrendsHandler --> GetFloodTrendsRequest : handles
GetFloodTrendsHandler --> GetFloodTrendsResponse : returns
GetFloodTrendsHandler ..> ISensorDailyAggRepository : uses
GetFloodTrendsHandler ..> IStationRepository : uses
GetFloodTrendsHandler ..> IFloodHistoryMapper : uses

GetFloodStatisticsHandler --> GetFloodStatisticsRequest : handles
GetFloodStatisticsHandler --> GetFloodStatisticsResponse : returns
GetFloodStatisticsHandler ..> ISensorDailyAggRepository : uses
GetFloodStatisticsHandler ..> IStationRepository : uses
GetFloodStatisticsHandler ..> IFloodHistoryMapper : uses

GetFloodHistoryResponse *-- FloodHistoryDto
GetFloodTrendsResponse *-- FloodTrendDto
GetFloodStatisticsResponse *-- FloodStatisticsDto

FloodHistoryDto *-- FloodDataPointDto
FloodTrendDto *-- FloodTrendDataPointDto

' ============================================
' LEGEND
' ============================================
legend bottom left
  | Color | Layer |
  | #E1D5E7 | Common Services |
  | #D5E8D4 | Application Layer (CQRS Handlers) |
  | #F8CECC | Domain Entities |
  | #FFE6CC | Domain Repositories |
  | | |
  | Line Style | Meaning |
  | --> | Dependency |
  | ..> | Uses/Sends |
  | ..\|> | Implements |
  | *-- | Composition |
  | | |
  | Features: |
  | G44 - Get Flood History (raw/hourly/daily) |
  | G45 - Get Flood Trends (with comparison) |
  | G46 - Get Flood Statistics (summary + breakdown) |
endlegend

@enduml
