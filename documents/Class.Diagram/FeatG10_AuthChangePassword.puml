@startuml FeatG10_AuthChangePassword_ClassDiagram
!define RECTANGLE class

skinparam backgroundColor #FEFEFE
skinparam classBackgroundColor #FFFFFF
skinparam classBorderColor #000000
skinparam packageBackgroundColor #E8E8E8
skinparam packageBorderColor #666666
skinparam stereotypeCBackgroundColor #ADD1B2
skinparam arrowColor #333333

title FeatG10_AuthChangePassword - Class Diagram\n(Domain-Centric Architecture + CQRS Pattern)

' ============================================
' PRESENTATION LAYER
' ============================================
package "PRESENTATION LAYER" #E1D5E7 {
  class ChangePasswordEndpoint <<Endpoint>> {
    - _mediator: IMediator
    --
    + Configure(): void
    + HandleAsync(req: ChangePasswordRequestDto, ct: CancellationToken): Task
  }

  class ChangePasswordRequestDto <<DTO>> {
    + CurrentPassword: string
    + NewPassword: string
    + ConfirmPassword: string
  }

  class ChangePasswordResponseDto <<DTO>> {
    + Success: bool
    + Message: string
  }

  ChangePasswordEndpoint --> ChangePasswordRequestDto : uses
  ChangePasswordEndpoint --> ChangePasswordResponseDto : returns
}

' ============================================
' APPLICATION LAYER
' ============================================
package "APPLICATION LAYER" #D5E8D4 {
  class ChangePasswordRequest <<Record>> {
    + UserId: Guid
    + CurrentPassword: string
    + NewPassword: string
    + ConfirmPassword: string
  }

  class ChangePasswordResponse <<Response>> {
    + Success: bool
    + Message: string
    + StatusCode: ChangePasswordResponseStatusCode
  }

  class ChangePasswordHandler <<Handler>> {
    - _userRepository: IUserRepository
    - _passwordHasher: IPasswordHasher
    - _refreshTokenRepository: IRefreshTokenRepository
    --
    + Handle(request: ChangePasswordRequest, ct): Task<ChangePasswordResponse>
    - ValidatePasswordStrength(password: string): (IsValid, ErrorMessage)
  }

  class ChangePasswordRequestValidator <<Validator>> {
    --
    + ChangePasswordRequestValidator()
  }

  interface IRequestHandler {
    + Handle(request, ct): Task<Response>
  }

  enum ChangePasswordResponseStatusCode <<Enumeration>> {
    Success
    UserNotFound
    CurrentPasswordIncorrect
    NewPasswordInvalid
    PasswordMismatch
    SameAsCurrentPassword
    UnknownError
  }

  ChangePasswordHandler ..|> IRequestHandler : implements
  ChangePasswordHandler --> ChangePasswordRequest : handles
  ChangePasswordHandler --> ChangePasswordResponse : returns
  ChangePasswordResponse --> ChangePasswordResponseStatusCode : contains
  ChangePasswordRequestValidator --> ChangePasswordRequest : validates
}

' ============================================
' DOMAIN LAYER - Entities
' ============================================
package "DOMAIN LAYER - Entities" #F8CECC {
  class User <<Entity>> {
    + Id: Guid
    + Email: string
    + PasswordHash: string?
    + CreatedAt: DateTime
    + UpdatedAt: DateTime
    + UpdatedBy: Guid
    + RefreshTokens: List<RefreshToken>
  }

  class RefreshToken <<Entity>> {
    + Id: Guid
    + UserId: Guid
    + Token: string
    + ExpiresAt: DateTime
    + IsRevoked: bool
    + CreatedAt: DateTime
  }

  User "1" *-- "many" RefreshToken : owns
}

' ============================================
' DOMAIN LAYER - Repositories
' ============================================
package "DOMAIN LAYER - Repositories" #FFE6CC {
  interface IUserRepository <<Interface>> {
    + GetByIdAsync(userId: Guid, ct): Task<User?>
    + UpdateAsync(user: User, ct): Task<bool>
  }

  interface IRefreshTokenRepository <<Interface>> {
    + RevokeAllUserTokensAsync(userId: Guid, ct): Task<bool>
  }
}

' ============================================
' COMMON SERVICES
' ============================================
package "COMMON SERVICES" #E1D5E7 {
  interface IMediator <<Interface>> {
    + Send<TResponse>(request, ct): Task<TResponse>
  }

  interface IPasswordHasher <<Interface>> {
    + HashPassword(password: string): string
    + VerifyPassword(password: string, hash: string): bool
  }

  interface IFeatureRequest <<Interface>> { }
  interface IFeatureResponse <<Interface>> { }

  ChangePasswordRequest ..|> IFeatureRequest
  ChangePasswordResponse ..|> IFeatureResponse
}

' ============================================
' RELATIONSHIPS
' ============================================
ChangePasswordEndpoint ..> IMediator : uses
ChangePasswordEndpoint ..> ChangePasswordRequest : sends

ChangePasswordHandler ..> IUserRepository : uses
ChangePasswordHandler ..> IPasswordHasher : uses
ChangePasswordHandler ..> IRefreshTokenRepository : uses

ChangePasswordRequestDto ..> ChangePasswordRequest : maps to
ChangePasswordResponseDto ..> ChangePasswordResponse : maps from

' ============================================
' LEGEND
' ============================================
legend bottom left
  | Color | Layer |
  | #E1D5E7 | Presentation Layer & Common Services |
  | #D5E8D4 | Application Layer |
  | #F8CECC | Domain Entities |
  | #FFE6CC | Domain Repositories |
  | | |
  | Line Style | Meaning |
  | --> | Dependency |
  | ..> | Uses/Sends |
  | ..\|> | Implements |
  | *-- | Composition (1 to Many) |
  | | |
  | Note: Requires JWT authentication |
endlegend

@enduml
